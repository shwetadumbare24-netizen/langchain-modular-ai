Memory Usage
conversation.predict(input="I love Python")

Agent Execution
executor.invoke({"input": "Calculate 100/5"})

Mini RAG Pipeline
retriever = vectorstore.as_retriever()

rag_chain = (
    {"context": retriever, "question": lambda x: x}
    | prompt
    | llm
    | StrOutputParser()
)

